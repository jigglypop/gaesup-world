{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "allowImportingTsExtensions": true,
    "allowArbitraryExtensions": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react",
    "baseUrl": ".",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@/*": ["src/*"],
      "gaesup-world": ["src/index.ts"],
      "gaesup-world/admin": ["src/admin-entry.ts"],
      "gaesup-world/assets": ["src/assets.ts"],
      "gaesup-world/blueprints": ["src/blueprints/index.ts"],
      "gaesup-world/blueprints/editor": ["src/blueprints/editor.ts"],
      "gaesup-world/building": ["src/building.ts"],
      "gaesup-world/editor": ["src/editor.ts"],
      "gaesup-world/gameplay": ["src/gameplay.ts"],
      "gaesup-world/navigation": ["src/navigation.ts"],
      "gaesup-world/network": ["src/network.ts"],
      "gaesup-world/postprocessing": ["src/postprocessing.ts"],
      "gaesup-world/plugins": ["src/plugins.ts"],
      "gaesup-world/runtime": ["src/runtime.ts"],
      "gaesup-world/server-contracts": ["src/server-contracts.ts"],
      "@core/*": ["src/core/*"],
      "@hooks/*": ["src/core/hooks/*"],
      "@stores/*": ["src/core/stores/*"],
      "@components/*": ["src/core/components/*"],
      "@constants/*": ["src/core/constants/*"],
      "@utils/*": ["src/core/utils/*"],
      "@types/*": ["src/core/types/*"],
      "@motions/*": ["src/core/motions/*"],
      "@debug/*": ["src/core/debug/*"]
    },
    "emitDecoratorMetadata": false
  },
  "include": ["src", "examples", "vite.config.ts", "jest.config.cjs", "index.ts", "react-three-fiber.d.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"],
  "ts-node": {
    "esm": true
  }
}
